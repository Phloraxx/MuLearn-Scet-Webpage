# Required - Cloudflare Worker URL for task/leaderboard API
# VITE_WORKER_URL=https://your-worker.workers.dev/api/woocommerce

# Required - Google OAuth Client ID (public-facing, safe in source)
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Required - Google Apps Script Web App URL for Karma War registration
# VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/your-script-id/exec

# Optional - MuID validation endpoint (defaults to https://tests.mulearnscet.in)
# VITE_MUID_VALIDATION_URL=https://tests.mulearnscet.in
